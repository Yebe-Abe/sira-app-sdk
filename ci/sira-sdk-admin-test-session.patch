diff --git a/packages/server/src/routes/admin.ts b/packages/server/src/routes/admin.ts
new file mode 100644
index 0000000..c22a664
--- /dev/null
+++ b/packages/server/src/routes/admin.ts
@@ -0,0 +1,42 @@
+import { Hono } from "hono";
+import { config } from "../config.js";
+import { sessions } from "../store.js";
+
+// Test-only admin endpoints. Gated by SIRA_TEST_KEY: when the env var is
+// unset, every endpoint here returns 404 and the router is effectively
+// inert. CI sets the var; production never does.
+//
+// The only endpoint right now is `mint a session bypassing agent auth` —
+// CI uses it to get a code its in-process test agent can claim. Frame
+// capture and annotation injection happen entirely on the CI side via the
+// existing public WS (the test agent connects as role=agent with the same
+// SIRA_TEST_KEY in the query string), so the server never needs to grow
+// frame-storage logic.
+
+export const adminRouter = new Hono();
+
+function gate(): boolean {
+  return Boolean(config.testKey);
+}
+
+adminRouter.use("/admin/*", async (c, next) => {
+  if (!gate()) {
+    return c.json({ error: "not_found" }, 404);
+  }
+  // Either header or query string — header is preferred but CI scripts that
+  // use simple curl find the query form easier.
+  const auth = c.req.header("x-sira-test-key") ?? c.req.query("testKey");
+  if (auth !== config.testKey) {
+    return c.json({ error: "forbidden" }, 403);
+  }
+  await next();
+});
+
+adminRouter.post("/admin/test-session", (c) => {
+  const session = sessions.createSession();
+  return c.json({
+    sessionId: session.id,
+    code: session.code,
+    expiresAt: session.codeExpiresAt,
+  });
+});
diff --git a/packages/server/src/routes/rtc.ts b/packages/server/src/routes/rtc.ts

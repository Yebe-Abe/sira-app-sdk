--- a/packages/server/src/routes/rtc.ts
+++ b/packages/server/src/routes/rtc.ts
@@ -3,6 +3,7 @@ import type { NodeWebSocket } from "@hono/node-ws";
 import { SignalClientMsg, type SignalServerMsg } from "@sira/shared";
 import { sessions } from "../store.js";
 import { readAgent } from "../auth.js";
+import { config } from "../config.js";
 import type { Context } from "hono";
 
 // Map sessionId -> { customer?: WSContext, agent?: WSContext }
@@ -30,7 +31,14 @@ export function buildRtcHandler(upgradeWebSocket: NodeWebSocket["upgradeWebSocke
     const valid = session && (role === "customer" || role === "agent");
     const agent = readAgent(c);
 
-    if (!valid || (role === "agent" && !agent)) {
+    // CI-only escape hatch: a role=agent connection that presents the
+    // configured SIRA_TEST_KEY (in header or query) is allowed without the
+    // agent cookie. Inert in production because config.testKey is unset.
+    const testKey = c.req.header("x-sira-test-key") ?? c.req.query("testKey");
+    const testAuthorized =
+      role === "agent" && config.testKey && testKey === config.testKey;
+
+    if (!valid || (role === "agent" && !agent && !testAuthorized)) {
       return {
         onOpen(_e: unknown, ws: WSContext) {
           send(ws, { t: "error", code: "bad_session", message: "session not valid" });
diff --git a/packages/shared/src/protocol.ts b/packages/shared/src/protocol.ts
index d460d8b..85e5ca7 100644
--- a/packages/shared/src/protocol.ts
+++ b/packages/shared/src/protocol.ts
@@ -42,6 +42,11 @@ export type SignalServerMsg = z.infer<typeof SignalServerMsg>;
 // rrweb events are untyped JSON from the recorder; we pass through opaquely.
 const RRWebEvent = z.unknown();
 
+// Native SDK runs on iOS/Android — declared here so the dashboard can adapt
+// framing (portrait vs. landscape, native frame viewer vs. rrweb replayer).
+export const Platform = z.enum(["web", "ios", "android"]);
+export type Platform = z.infer<typeof Platform>;
+
 // Customer -> Agent: DOM stream + viewport metadata + session control.
 export const StreamMsg = z.discriminatedUnion("t", [
   z.object({
@@ -49,11 +54,24 @@ export const StreamMsg = z.discriminatedUnion("t", [
     events: z.array(RRWebEvent),
     seq: z.number().int().nonnegative(),
   }),
+  // Native screen-share variant. Customers on iOS/Android cannot send DOM
+  // events (no DOM); they ship WebP frames over the same channel. Receivers
+  // discriminate on `t` so this is fully additive to the web flow.
+  z.object({
+    t: z.literal("frame"),
+    seq: z.number().int().nonnegative(),
+    ts: z.number().int().nonnegative(),
+    webp: z.string(), // base64
+    w: z.number().int().positive(),
+    h: z.number().int().positive(),
+  }),
   z.object({
     t: z.literal("viewport"),
     w: z.number().int().positive(),
     h: z.number().int().positive(),
     dpr: z.number().positive(),
+    // Optional for backward compat with the web SDK that doesn't set it.
+    platform: Platform.optional(),
   }),
   // Window scroll position, sent on session start, on SPA nav, and throttled
   // during scrolling. rrweb's Replayer handles scroll events well *during* a
